# Copy this file to /opt/campus-recruitment/.env on the server and edit values.

SERVER_PORT=8081
SERVER_CONTEXT_PATH=/api

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_recruitment
DB_USERNAME=campus_user
DB_PASSWORD=change_me

# Use a long random value in production.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE=604800000

CAMPUS_UPLOAD_PATH=/opt/campus-recruitment/upload/
CAMPUS_UPLOAD_PREFIX=/upload/

LOG_FILE=/opt/campus-recruitment/logs/campus-recruitment.log
LOG_LEVEL_ROOT=info
LOG_LEVEL_CAMPUS=info

JAVA_OPTS="-Xms256m -Xmx512m"
